{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}
        clj-http/clj-http {:mvn/version "3.13.0"}
        clj-commons/clj-yaml {:mvn/version "1.0.27"}
        http-kit/http-kit {:mvn/version "2.8.0"}
        ;; Datomic, in-process (mem: for tests/dev, file for persistence). Same datomic.client.api
        ;; targets Datomic Pro/Cloud unchanged.
        com.datomic/local {:mvn/version "1.0.291"}}
 :aliases
 {;; clojure -X:test
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :exec-fn cognitect.test-runner.api/test}
  ;; clojure -M:run
  :run {:main-opts ["-m" "agentic.main"]}
  ;; clojure -M:http  — HTTP front door (Agent Card + POST /agent) on :8080
  :http {:main-opts ["-m" "agentic.http"]}
  ;; clojure -M:mcp   — MCP stdio server exposing the tool registry
  :mcp {:main-opts ["-m" "agentic.mcp"]}
  ;; clojure -M:time-travel — Datomic transcript time-travel showcase (as-of replay)
  :time-travel {:main-opts ["-m" "agentic.example.time-travel"]}}}

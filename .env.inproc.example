# In-process JPype runtime — no cluster, no docker. The notebook starts a JVM
# inside its own Python process and calls operators directly. Same flow as
# notebooks 07/08 historically.
#
#   cp .env.inproc.example .env
#   /Users/bengamble/Agentic-Flink/.venv/bin/jupyter notebook notebooks/07_market_depth_agents.ipynb

AGENTIC_FLINK_MODE=inproc


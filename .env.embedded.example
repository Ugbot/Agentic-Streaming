# Embedded MiniCluster runtime — JPype JVM + an in-process Flink MiniCluster.
# No docker; useful for offline testing of the full job graph including ZMQ
# chains and Fluss sinks (provided you have Fluss locally available or use
# in-memory alternatives).
#
#   cp .env.embedded.example .env
#   /Users/bengamble/Agentic-Flink/.venv/bin/jupyter notebook notebooks/09_session_cluster_levels.ipynb
#
# Caveats:
#   - No central JM REST; the notebook's `client.jobs()` / `cancel()` calls are
#     best-effort per-thread.
#   - Heavier than `inproc` since each level spins a transient cluster, but
#     much lighter than the dockerised session cluster.

AGENTIC_FLINK_MODE=embedded

ANTHROPIC_API_KEY=

# Session runtime pointed at a REMOTE Flink session cluster. No local podman
# needed — assumes the cluster is reachable at the URL below.
#
#   cp .env.cluster.remote.example .env
#   # edit FLINK_REST_URL / FLUSS_BOOTSTRAP to match your cluster
#
# Note: the notebook's cross-level ZeroMQ chain endpoints (tcp://flink-taskmanager:5560 etc.)
# assume container DNS inside the cluster. For a remote cluster, point them at
# the TaskManager's reachable host/IP — or use the alerts-pub :5557 tap, which
# is forwarded to the host that runs the cluster.

AGENTIC_FLINK_MODE=session
FLINK_REST_URL=http://10.0.0.5:8081      # change to your remote
FLUSS_BOOTSTRAP=10.0.0.5:9123

ANTHROPIC_API_KEY=

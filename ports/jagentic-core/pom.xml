<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>org.jagentic</groupId>
  <artifactId>jagentic-core</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>
  <name>jagentic-core</name>
  <description>Pure-Java, Flink-free essence of Agentic-Flink — the shared core the
    Kafka Streams / Spring / Quarkus ports build on (Java mirror of ports/pyagentic).</description>

  <properties>
    <maven.compiler.release>17</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <langchain4j.version>1.16.3</langchain4j.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <!-- LangChain4J BOM aligns the optional provider modules to one version. -->
      <dependency>
        <groupId>dev.langchain4j</groupId>
        <artifactId>langchain4j-bom</artifactId>
        <version>${langchain4j.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <!-- JSON for the LLM brain's HTTP chat clients (Ollama/OpenAI). The essence
         classes stay dependency-free; only the optional LLM provider clients use it. -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.17.2</version>
    </dependency>
    <!-- YAML for the declarative pipeline loader (same pipeline.yaml schema as Python/Go). -->
    <dependency>
      <groupId>com.fasterxml.jackson.dataformat</groupId>
      <artifactId>jackson-dataformat-yaml</artifactId>
      <version>2.17.2</version>
    </dependency>

    <!-- LangChain4J: real multi-provider chat + embeddings (Ollama/OpenAI/Anthropic/
         Gemini), the same library + version the Flink framework uses. Optional at
         runtime — the model-free Stub/hashing defaults need none of it. -->
    <dependency>
      <groupId>dev.langchain4j</groupId>
      <artifactId>langchain4j-ollama</artifactId>
      <optional>true</optional>
    </dependency>
    <dependency>
      <groupId>dev.langchain4j</groupId>
      <artifactId>langchain4j-open-ai</artifactId>
      <optional>true</optional>
    </dependency>

    <!-- Reference store impls (optional; the in-memory defaults need none of them).
         Qdrant uses java.net.http (no dep); Postgres uses JDBC; Redis uses Jedis. -->
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <version>42.7.4</version>
      <optional>true</optional>
    </dependency>
    <dependency>
      <groupId>redis.clients</groupId>
      <artifactId>jedis</artifactId>
      <version>5.1.5</version>
      <optional>true</optional>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.10.2</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.5</version>
      </plugin>
    </plugins>
  </build>
</project>
